# AmourScans Environment Configuration
# Copy this file to .env and configure for your deployment

# =============================================================================
# SERVER CONFIGURATION (Required for Production)
# =============================================================================

# Node environment: 'development' | 'production' | 'test'
NODE_ENV=production

# Server port (most hosting platforms provide this automatically)
PORT=5000

# Production URL - Your full domain URL (required for OAuth callbacks and sitemap)
# Examples: https://your-app.onrender.com, https://your-app.railway.app
PRODUCTION_URL=https://your-domain.com

# =============================================================================
# DATABASE CONFIGURATION (Optional - uses defaults if not set)
# =============================================================================

# Path to SQLite database file (default: ./data/database.db)
DATABASE_PATH=./data/database.db

# Enable slow query logging (default: disabled in production)
LOG_SLOW_QUERIES=false

# =============================================================================
# ADMIN CONFIGURATION (Optional - auto-generates secure defaults)
# =============================================================================

# Admin username (default: admin)
ADMIN_USERNAME=admin

# Admin email (default: admin@localhost.com)
ADMIN_EMAIL=admin@yourdomain.com

# Admin password (default: auto-generated strong password in production)
# IMPORTANT: Set this to a secure password for production
ADMIN_PASSWORD=your_secure_password_here

# =============================================================================
# SECURITY (Auto-generated if not set - recommended to leave blank)
# =============================================================================

# Session secret for authentication (auto-generated if not set)
# SESSION_SECRET=auto_generated_on_startup

# Session secret for authentication (set this explicitly - do not commit .key files)
# CRITICAL: Set this in your hosting platform environment variables
SESSION_SECRET=generate_a_64_char_random_hex_string_here

# CSRF protection secret (set this explicitly - do not commit .key files)
# CRITICAL: Set this in your hosting platform environment variables
CSRF_SECRET=generate_a_64_char_random_hex_string_here

# =============================================================================
# EMAIL CONFIGURATION (Optional - for password reset and notifications)
# =============================================================================

# SendGrid (Recommended for production)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# OR SMTP Configuration (Alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email for DMCA notifications
DMCA_NOTIFICATION_EMAIL=admin@yourdomain.com

# =============================================================================
# PAYMENT INTEGRATION (Optional - for monetization features)
# =============================================================================

# Stripe keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# OAUTH PROVIDERS (Optional - for social login)
# =============================================================================

# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Discord OAuth (get from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# =============================================================================
# REPLIT-SPECIFIC (Auto-provided by Replit - do not set manually)
# =============================================================================

# Replit automatically provides these variables:
# REPLIT_DOMAINS - Your replit domain
# REPLIT_DEV_DOMAIN - Development domain
# These are used as fallbacks when PRODUCTION_URL is not set

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# REQUIRED FOR PRODUCTION:
# - NODE_ENV=production
# - PRODUCTION_URL=https://your-actual-domain.com
# - ADMIN_PASSWORD (or auto-generated on first startup)

# RECOMMENDED FOR PRODUCTION:
# - SENDGRID_API_KEY or SMTP configuration
# - STRIPE keys if using monetization
# - Custom ADMIN_EMAIL

# OPTIONAL:
# - All OAuth provider credentials (if using social login)
# - DATABASE_PATH (uses default ./data/database.db)
# - SESSION_SECRET and CSRF_SECRET (auto-generated if not set)

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================

# 1. Never commit .env file to version control (add to .gitignore)
# 2. Use different credentials for development and production
# 3. Rotate secrets regularly in production
# 4. Use strong, unique passwords for all services
# 5. Store secrets securely in your hosting platform's secret manager
